# ---- Coordination API ----
SR_COORDINATION_API_URL=http://localhost:8000
SR_COORDINATION_API_SECRET=change_me

# ---- Bright Data TLS ----
# Path to Bright Data CA certificate (PEM). Bundled at certs/brightdata-ca.crt.
SR_BRIGHTDATA_CA_CERT=certs/brightdata-ca.crt

# ---- TLS ----
SR_NODE_TLS_VERIFY=true

# ---- Performance ----
SR_DEFAULT_RATE_LIMIT_RPM=60
SR_NODE_REQUEST_TIMEOUT=30.0

# ---- Optional: Supabase direct logging ----
# SR_SUPABASE_URL=https://your-project.supabase.co
# SR_SUPABASE_SERVICE_KEY=your_service_key

# ---- Bright Data fallback proxy ----
SR_BRIGHTDATA_ACCOUNT_ID=your_account_id
SR_BRIGHTDATA_ZONE=your_zone_name
SR_BRIGHTDATA_PASSWORD=your_password
SR_BRIGHTDATA_HOST=brd.superproxy.io
SR_BRIGHTDATA_PORT=33335
# Path to Bright Data CA certificate (PEM). Bundled at certs/brightdata-ca.crt.
SR_BRIGHTDATA_CA_CERT=certs/brightdata-ca.crt

# ---- Creditcoin staking verification ----
SR_STAKING_CONTRACT_ADDRESS=    # EVM address of the deployed staking contract
SR_CREDITCOIN_RPC_URL=https://mainnet3.creditcoin.network

# ---- Database ----
SR_USE_SQLITE=true
SR_SQLITE_DB_PATH=space_router.db
# For production (Supabase):
# SR_USE_SQLITE=false
# SR_SUPABASE_URL=https://your-project.supabase.co
# SR_SUPABASE_SERVICE_KEY=your_service_key

# ---- Internal API auth ----
SR_INTERNAL_API_SECRET=change_me

# ---- Optional: ipinfo.io ----
# SR_IPINFO_TOKEN=your_token
